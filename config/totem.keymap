#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

#define BASE_WIN 0
#define BASE_MAC 1
#define NAV_L    2
#define NAV_R    3
#define NUM      4
#define SYM      5
#define FUN      6
#define MOUSE_L  7
#define MOUSE_R  8
#define SYS_L    9
#define SYS_R    10
#define IME      11

/ {
    behaviors {
        /*
         * Positional / bilateral home-row mods.
         *
         * Totem matrix positions from the existing file:
         *   left hand:  top 0-4,  home 10-14, bottom 21-25, thumbs 32-34
         *   right hand: top 5-9,  home 15-19, bottom 26-30, thumbs 35-37
         *
         * Ignored outer pinky keys are positions 20 and 31.
         */
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <5 6 7 8 9 15 16 17 18 19 26 27 28 29 30 35 36 37>;
            hold-trigger-on-release;
        };

        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <0 1 2 3 4 10 11 12 13 14 21 22 23 24 25 32 33 34>;
            hold-trigger-on-release;
        };

        /* Sticky Shift for one capital letter or one shifted symbol. */
        skq: sticky_key_quick {
            compatible = "zmk,behavior-sticky-key";
            #binding-cells = <1>;
            bindings = <&kp>;
            release-after-ms = <1500>;
            quick-release;
            ignore-modifiers;
        };

        /*
         * Lazy sticky modifiers are useful for GUI/Alt-style modifiers and
         * mouse interactions because the host does not see the modifier unless
         * a following key uses it.
         */
        skl: sticky_key_lazy {
            compatible = "zmk,behavior-sticky-key";
            #binding-cells = <1>;
            bindings = <&kp>;
            release-after-ms = <1500>;
            lazy;
            ignore-modifiers;
        };
    };

    macros {
        /*
         * IME fallback placeholders.
         * Prefer LANG1/LANG2 when the host supports them.
         */
        ime_ctrl_space: ime_ctrl_space {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LCTRL>
                , <&macro_tap &kp SPACE>
                , <&macro_release &kp LCTRL>
                ;
        };

        ime_gui_space: ime_gui_space {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_tap &kp SPACE>
                , <&macro_release &kp LGUI>
                ;
        };

        /*
         * Programming symbol macros.
         * These avoid duplicating symbols that NUM + Shift can already type.
         */
        eqeq: eqeq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp EQUAL>
                , <&macro_tap &kp EQUAL>
                ;
        };

        neq: neq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(N1)>     /* ! */
                , <&macro_tap &kp EQUAL>
                ;
        };

        leq: leq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(COMMA)>  /* < */
                , <&macro_tap &kp EQUAL>
                ;
        };

        geq: geq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(DOT)>    /* > */
                , <&macro_tap &kp EQUAL>
                ;
        };

        andand: andand {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(N7)>     /* & */
                , <&macro_tap &kp LS(N7)>
                ;
        };

        oror: oror {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(BSLH)>   /* | */
                , <&macro_tap &kp LS(BSLH)>
                ;
        };

        arrow_r: arrow_r {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp MINUS>
                , <&macro_tap &kp LS(DOT)>    /* > */
                ;
        };

        fat_arrow: fat_arrow {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp EQUAL>
                , <&macro_tap &kp LS(DOT)>    /* > */
                ;
        };

        coloncolon: coloncolon {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(SEMI)>   /* : */
                , <&macro_tap &kp LS(SEMI)>
                ;
        };
    };

    combos {
        compatible = "zmk,combos";

        /*
         * Base same-hand punctuation combos.
         * No cross-half alpha combos.
         */

        combo_esc {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <0 1>;      /* Q + W */
            bindings = <&kp ESC>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_ime_as {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <10 11>;    /* A + S */
            bindings = <&lt IME LANG1>; /* tap = 한/영, hold = IME layer */
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_grave_zx {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <21 22>;    /* Z + X */
            bindings = <&kp GRAVE>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_del {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <8 9>;      /* O + P */
            bindings = <&kp DEL>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_squote {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <18 19>;    /* L + ;, below Del */
            bindings = <&kp SQT>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_backslash {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <29 30>;    /* . + / */
            bindings = <&kp BSLH>;
            layers = <BASE_WIN BASE_MAC>;
        };

        /*
         * Optional sticky modifiers.
         * Keep these small at first. Delete if they misfire.
         */
        combo_sticky_shift_left {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <11 12>;    /* S + D */
            bindings = <&skq LSHFT>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_sticky_shift_right {
            timeout-ms = <35>;
            require-prior-idle-ms = <200>;
            key-positions = <17 18>;    /* K + L */
            bindings = <&skq RSHFT>;
            layers = <BASE_WIN BASE_MAC>;
        };

        /*
         * Thumb-cluster layer combos.
         *
         * Physical thumb order:
         *   32 Tab | 33 Space | 34 NAV_L || 35 NAV_R | 36 Backspace | 37 Enter
         *
         * NUM/SYM/FUN stay cross-hand. SYS has left/right same-side combos.
         */
        combo_num_thumb {
            timeout-ms = <70>;
            require-prior-idle-ms = <200>;
            key-positions = <33 36>;    /* Space + Backspace */
            bindings = <&mo NUM>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_sym_thumb {
            timeout-ms = <70>;
            require-prior-idle-ms = <200>;
            key-positions = <33 37>;    /* Space + Enter */
            bindings = <&mo SYM>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_fun_thumb {
            timeout-ms = <70>;
            require-prior-idle-ms = <200>;
            key-positions = <32 37>;    /* Tab + Enter */
            bindings = <&mo FUN>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_sys_l_thumb {
            timeout-ms = <70>;
            require-prior-idle-ms = <200>;
            key-positions = <32 34>;    /* Tab + NAV_L */
            bindings = <&mo SYS_L>;
            layers = <BASE_WIN BASE_MAC>;
        };

        combo_sys_r_thumb {
            timeout-ms = <70>;
            require-prior-idle-ms = <200>;
            key-positions = <35 37>;    /* NAV_R + Enter */
            bindings = <&mo SYS_R>;
            layers = <BASE_WIN BASE_MAC>;
        };

        /*
         * Mouse toggle:
         * arrow-layer thumb + same-hand index home-row key.
         */
        combo_mouse_l {
            timeout-ms = <60>;
            require-prior-idle-ms = <200>;
            key-positions = <13 34>;    /* F + NAV_L thumb */
            bindings = <&tog MOUSE_L>;
            layers = <BASE_WIN BASE_MAC NAV_L MOUSE_L>;
        };

        combo_mouse_r {
            timeout-ms = <60>;
            require-prior-idle-ms = <200>;
            key-positions = <16 35>;    /* J + NAV_R thumb */
            bindings = <&tog MOUSE_R>;
            layers = <BASE_WIN BASE_MAC NAV_R MOUSE_R>;
        };

        /*
         * Light-switch guard combos.
         * If these five keys are accidentally mashed together, emit nothing.
         *
         * Right side: J K L ; + NAV_R thumb.
         * Left mirror: A S D F + NAV_L thumb.
         */
        combo_guard_left {
            timeout-ms = <100>;
            require-prior-idle-ms = <200>;
            key-positions = <10 11 12 13 34>;  /* A S D F + NAV_L */
            bindings = <&none>;
            layers = <BASE_WIN BASE_MAC NAV_L>;
        };

        combo_guard_right {
            timeout-ms = <100>;
            require-prior-idle-ms = <200>;
            key-positions = <16 17 18 19 35>;  /* J K L ; + NAV_R */
            bindings = <&none>;
            layers = <BASE_WIN BASE_MAC NAV_R>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /*
         * BASE_WIN: Windows/Linux base.
         *
         * Thumb order:
         *   Tab - Space - NAV_L - NAV_R - Backspace - Enter
         *
         * Home-row mods:
         *   left:  A=GUI, S=Alt, D=Ctrl, F=Shift
         *   right: J=Shift, K=Ctrl, L=Alt, ;=GUI
         */
        base_win {
            display-name = "BASE_WIN";
            bindings = <
        &kp Q        &kp W        &kp E          &kp R        &kp T          &kp Y        &kp U        &kp I        &kp O        &kp P
        &hml LGUI A  &hml LALT S  &hml LCTRL D   &hml LSHFT F &kp G          &kp H        &hmr RSHFT J &hmr RCTRL K &hmr RALT L  &hmr RGUI SEMI
&none   &kp Z        &kp X        &kp C          &kp V        &kp B          &kp N        &kp M        &kp COMMA    &kp DOT      &kp FSLH     &none
                                      &kp TAB      &kp SPACE    &mo NAV_L      &mo NAV_R    &kp BSPC     &kp ENTER
            >;
        };

        /*
         * BASE_MAC: macOS base.
         *
         * Command is GUI in HID terms.
         * Option is Alt in HID terms.
         *
         * Home-row mods:
         *   left:  A=Option, S=Control, D=Command, F=Shift
         *   right: J=Shift, K=Command, L=Control, ;=Option
         */
        base_mac {
            display-name = "BASE_MAC";
            bindings = <
        &kp Q        &kp W         &kp E        &kp R        &kp T          &kp Y        &kp U        &kp I       &kp O         &kp P
        &hml LALT A  &hml LCTRL S  &hml LGUI D  &hml LSHFT F &kp G          &kp H        &hmr RSHFT J &hmr RGUI K &hmr RCTRL L  &hmr RALT SEMI
&none   &kp Z        &kp X         &kp C        &kp V        &kp B          &kp N        &kp M        &kp COMMA   &kp DOT       &kp FSLH      &none
                                      &kp TAB     &kp SPACE    &mo NAV_L    &mo NAV_R    &kp BSPC     &kp ENTER
            >;
        };

        /*
         * NAV_L:
         * Left-hand mirrored navigation.
         * Right side stays transparent so right-hand HRMs can modify arrows.
         *
         * Pure mirror of right HJKL:
         *   S = Right, D = Up, F = Down, G = Left
         */
        nav_l {
            display-name = "NAV_L";
            bindings = <
        &kp DEL      &kp END       &kp PG_UP    &kp PG_DN    &kp HOME       &trans       &trans       &trans       &trans       &trans
        &kp ESC      &kp RIGHT     &kp UP       &kp DOWN     &kp LEFT       &trans       &trans       &trans       &trans       &trans
&none   &tog MOUSE_L &trans        &trans       &caps_word   &key_repeat    &trans       &trans       &trans       &trans       &trans      &none
                                      &trans      &trans       &trans        &trans       &trans       &trans
            >;
        };

        /*
         * NAV_R:
         * Right-hand HJKL navigation.
         * Left side stays transparent so left-hand HRMs can modify arrows.
         *
         *   H = Left, J = Down, K = Up, L = Right
         */
        nav_r {
            display-name = "NAV_R";
            bindings = <
        &trans      &trans      &trans      &trans      &trans        &kp HOME      &kp PG_DN    &kp PG_UP    &kp END      &kp DEL
        &trans      &trans      &trans      &trans      &trans        &kp LEFT      &kp DOWN     &kp UP       &kp RIGHT    &kp ESC
&none   &trans      &trans      &trans      &trans      &trans        &key_repeat   &caps_word   &trans       &trans       &tog MOUSE_R &none
                                    &trans   &trans      &trans       &trans        &trans       &trans
            >;
        };

        /*
         * NUM:
         * Number-row style.
         *
         * Top row:
         *   1 2 3 4 5 | 6 7 8 9 0
         *
         * Home row stays transparent so HRMs can produce:
         *   Ctrl/Cmd/Alt/Shift + number.
         */
        num {
            display-name = "NUM";
            bindings = <
        &kp N1       &kp N2       &kp N3       &kp N4       &kp N5         &kp N6       &kp N7       &kp N8       &kp N9       &kp N0
        &trans       &trans       &trans       &trans       &trans         &trans       &trans       &trans       &trans       &trans
&none   &kp MINUS    &kp EQUAL    &kp DOT      &kp PLUS     &kp FSLH       &kp FSLH     &kp PLUS     &kp DOT      &kp EQUAL    &kp MINUS   &none
                                    &trans      &trans       &trans        &trans       &trans       &trans
            >;
        };

        /*
         * SYM:
         * Programming-symbol layer with fewer duplicates against NUM + Shift.
         *
         * Top row:
         *   [ { ( < <= | >= > ) } ]
         *
         * Home row:
         *   = == != ! | | & && || ^ ~
         *
         * Bottom row:
         *   ` ' " \ _ | - + * / ::
         */
        sym {
            display-name = "SYM";
            bindings = <
        &kp LBKT     &kp LS(LBKT) &kp LS(N9)    &kp LS(COMMA) &leq           &geq         &kp LS(DOT)  &kp LS(N0)   &kp LS(RBKT) &kp RBKT
        &kp EQUAL    &eqeq        &neq          &kp LS(N1)    &kp LS(BSLH)   &kp LS(N7)   &andand      &oror        &kp LS(N6)   &kp LS(GRAVE)
&none   &kp GRAVE    &kp SQT      &kp LS(SQT)   &kp BSLH      &kp LS(MINUS)  &kp MINUS    &kp PLUS     &kp STAR     &kp FSLH     &coloncolon &none
                                      &trans      &trans        &trans        &trans       &trans       &trans
            >;
        };

        /*
         * FUN:
         * Function keys match NUM positions.
         *
         * Top row:
         *   F1 F2 F3 F4 F5 | F6 F7 F8 F9 F10
         *
         * Bottom row:
         *   F11-F20
         */
        fun {
            display-name = "FUN";
            bindings = <
        &kp F1       &kp F2       &kp F3       &kp F4       &kp F5         &kp F6       &kp F7       &kp F8       &kp F9       &kp F10
        &trans       &trans       &trans       &trans       &trans         &trans       &trans       &trans       &trans       &trans
&none   &kp F11      &kp F12      &kp F13      &kp F14      &kp F15        &kp F16      &kp F17      &kp F18      &kp F19      &kp F20     &none
                                    &trans      &trans       &trans        &trans       &trans       &trans
            >;
        };

        /*
         * MOUSE_L:
         * Left side moves and scrolls.
         * Left thumb cluster is mirrored:
         *   32 = Middle click, 33 = Right click, 34 = Left click
         */
        mouse_l {
            display-name = "MOUSE_L";
            bindings = <
        &trans       &trans          &trans          &trans           &trans          &trans      &trans      &trans      &trans      &trans
        &trans       &mmv MOVE_RIGHT &mmv MOVE_UP    &mmv MOVE_DOWN   &mmv MOVE_LEFT  &trans      &trans      &trans      &trans      &trans
&none   &tog MOUSE_L &msc SCRL_RIGHT &msc SCRL_UP    &msc SCRL_DOWN   &msc SCRL_LEFT  &trans      &trans      &trans      &trans      &trans      &none
                                      &mkp MCLK       &mkp RCLK        &mkp LCLK      &trans      &trans      &trans
            >;
        };

        /*
         * MOUSE_R:
         * Right side moves and scrolls.
         * Right thumb cluster:
         *   35 = Left click, 36 = Right click, 37 = Middle click
         *
         * H/J/K/L = Move Left/Down/Up/Right.
         * N/M/,/. = Scroll Left/Down/Up/Right.
         */
        mouse_r {
            display-name = "MOUSE_R";
            bindings = <
        &trans      &trans      &trans      &trans      &trans        &trans          &trans          &trans          &trans           &trans
        &trans      &trans      &trans      &trans      &trans        &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_UP    &mmv MOVE_RIGHT  &trans
&none   &trans      &trans      &trans      &trans      &trans        &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_UP    &msc SCRL_RIGHT  &tog MOUSE_R &none
                                    &trans   &trans      &trans       &mkp LCLK       &mkp RCLK       &mkp MCLK
            >;
        };

        /*
         * SYS_L:
         * Access: Tab + NAV_L thumb combo.
         *
         * Bluetooth profile convention:
         *   BT0 = Windows
         *   BT1 = Linux
         *   BT2 = macOS
         *   BT3/BT4 = spare
         */
        sys_l {
            display-name = "SYS_L";
            bindings = <
        &to BASE_WIN &to BASE_MAC &out OUT_USB &out OUT_BLE &out OUT_TOG    &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
        &mo NAV_L    &mo NUM      &mo SYM     &mo FUN      &tog MOUSE_L    &bt BT_CLR    &skq LSHFT     &sk LCTRL      &skl LALT      &skl LGUI
&sys_reset &tog NAV_L &tog NUM    &tog SYM    &tog FUN     &tog MOUSE_R    &kp C_MUTE    &kp C_VOL_DN   &kp C_VOL_UP   &kp C_PP       &key_repeat   &bootloader
                                      &trans    &trans      &trans         &trans        &trans         &trans
            >;
        };

        /*
         * SYS_R:
         * Access: NAV_R + Enter thumb combo.
         *
         * Same bindings as SYS_L for now so either hand can reach system
         * controls without a cross-hand combo.
         */
        sys_r {
            display-name = "SYS_R";
            bindings = <
        &to BASE_WIN &to BASE_MAC &out OUT_USB &out OUT_BLE &out OUT_TOG    &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
        &mo NAV_L    &mo NUM      &mo SYM     &mo FUN      &tog MOUSE_L    &bt BT_CLR    &skq LSHFT     &sk LCTRL      &skl LALT      &skl LGUI
&sys_reset &tog NAV_L &tog NUM    &tog SYM    &tog FUN     &tog MOUSE_R    &kp C_MUTE    &kp C_VOL_DN   &kp C_VOL_UP   &kp C_PP       &key_repeat   &bootloader
                                      &trans    &trans      &trans         &trans        &trans         &trans
            >;
        };

        /*
         * IME:
         * Access:
         *   A + S tap  = LANG1 / 한영
         *   A + S hold = IME layer
         */
        ime {
            display-name = "IME";
            bindings = <
        &kp LANG1   &kp LANG2    &ime_ctrl_space &ime_gui_space &caps_word     &to BASE_WIN  &to BASE_MAC  &mo NAV_L    &mo NAV_R    &mo FUN
        &skq LSHFT  &sk LCTRL    &skl LALT       &skl LGUI      &mo NUM        &kp LANG1     &kp LANG2     &mo SYM      &tog MOUSE_L &tog MOUSE_R
&none   &trans      &trans       &trans          &trans         &trans         &trans        &trans        &trans       &trans       &trans      &none
                                  &trans          &trans         &trans         &trans        &trans        &trans
            >;
        };
    };
};
